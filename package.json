{
  "name": "jwt-pizza-service",
  "description": "Backend service for making JWT pizzas",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "cd src && node index.js",
    "lint": "eslint src/**/*.js",
    "test": "jest --coverage"
  },
  "license": "MIT",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.6",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "mysql2": "^3.9.7"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "eslint": "^9.39.2",
    "globals": "^17.3.0",
    "jest": "^30.2.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js",
      "!src/init.js",
      "!src/service.js"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  }
}
